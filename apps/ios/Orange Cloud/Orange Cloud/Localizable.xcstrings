    "关闭后，%@ 的安全级别将恢复为「中」。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Once disabled, the security level of %@ will return to Medium."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tras desactivarlo, el nivel de seguridad de %@ volverá a “Medio”."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無効にすると、%@ のセキュリティレベルは「中」に戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "끄면 %@의 보안 수준이 ‘보통’으로 돌아갑니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Após desativar, o nível de segurança de %@ voltará para “Médio”."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Após desativar, o nível de segurança de %@ voltará para “Médio”."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "關閉後，%@ 的安全層級將恢復為「中」。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "關閉後，%@ 的安全級別將恢復為「中」。"
          }
        }
      }
    },
    "关闭后，%@ 立即恢复缓存加速。" : {
