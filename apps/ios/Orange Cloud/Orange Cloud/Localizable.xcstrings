  "strings" : {
    "此设备不支持设备端 AI（需要 iOS 26 及支持 Apple 智能的机型）。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This device doesn’t support on-device AI (requires iOS 26 and an Apple Intelligence–capable model)."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este dispositivo no admite IA en el dispositivo (requiere iOS 26 y un modelo compatible con Apple Intelligence)."
